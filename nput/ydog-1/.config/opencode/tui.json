{
  "$schema": "https://opencode.ai/tui.json",
  "keybinds": {
    "messages_line_up": "ctrl+k",
    "messages_line_down": "ctrl+j",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
    "input_newline": "shift+return,ctrl+return,alt+return",
    "input_move_left": "left,ctrl+b,ctrl+h",
    "input_move_right": "right,ctrl+f,ctrl+l",
    "input_move_up": "up,ctrl+k",
    "input_move_down": "down,ctrl+j",
    "input_delete_to_line_end": false,
    "input_delete_to_line_start": false,
    "input_delete": "delete,shift+delete",
    "history_previous": "up,ctrl+k",
    "history_next": "down,ctrl+j",
    "session_child_first": "down,ctrl+j",
    "session_child_cycle": "right,l,ctrl+l",
    "session_child_cycle_reverse": "left,h,ctrl+h",
    "session_parent": "up,ctrl+k",
    "dialog.select.prev": "up,ctrl+p,ctrl+k",
    "dialog.select.next": "down,ctrl+n,ctrl+j",
    "prompt.autocomplete.prev": "up,ctrl+p,ctrl+k",
    "prompt.autocomplete.next": "down,ctrl+n,ctrl+j",
    "which_key_group_previous": "ctrl+alt+left,ctrl+alt+[,h,ctrl+h",
    "which_key_group_next": "ctrl+alt+right,ctrl+alt+],l,ctrl+l",
    "which_key_scroll_up": "ctrl+alt+up,ctrl+alt+p,ctrl+k",
    "which_key_scroll_down": "ctrl+alt+down,ctrl+alt+n,ctrl+j"
  }
}
